#!/usr/bin/make -f

# Keep Go's build cache inside the package build tree rather than
# touching $HOME (which may not exist/be writable in a clean build
# chroot), and avoid any module-proxy network access during a Debian
# build — go.sum already pins every dependency.
export GOCACHE := $(CURDIR)/debian/.gocache
export GOFLAGS := -mod=mod
export GO111MODULE := on
export CGO_ENABLED := 0

DEB_BUILD_ARCH   := $(shell dpkg-architecture -qDEB_BUILD_ARCH)
DEB_HOST_ARCH    := $(shell dpkg-architecture -qDEB_HOST_ARCH)
CROSS_COMPILING  := $(filter-out $(DEB_BUILD_ARCH),$(DEB_HOST_ARCH))

ifneq ($(CROSS_COMPILING),)
# Cross-compiling (e.g. building for arm64 on an amd64 host, invoked via
# `dpkg-buildpackage -aarm64`). No cross toolchain or PKG_CONFIG_LIBDIR
# dance needed here, unlike the sibling picam-orchestrator-go's cgo/libvpx
# build — CGO_ENABLED=0 above means this is a plain static Go cross-build,
# for which GOARCH is the only thing that actually matters.
export GOOS   := linux
export GOARCH := $(subst aarch64,arm64,$(shell dpkg-architecture -qDEB_HOST_GNU_CPU))
endif

%:
	dh $@

override_dh_auto_build:
	go build -trimpath -o picam-frontend ./cmd/picam-frontend

override_dh_auto_test:
ifeq ($(CROSS_COMPILING),)
	go vet ./...
	go test ./...
else
	# go vet only compiles, never executes the target binary, so it's
	# safe to keep even cross-compiling. go test is skipped: it needs to
	# actually RUN the compiled test binary, which this
	# $(DEB_BUILD_ARCH) build host can't do for a $(DEB_HOST_ARCH)
	# binary without emulation.
	go vet ./...
endif

override_dh_auto_install:
	install -D -m 0755 picam-frontend debian/picam-frontend/usr/bin/picam-frontend
	install -D -m 0644 config.ini debian/picam-frontend/etc/picam-frontend/config.ini
	install -d debian/picam-frontend/usr/share/picam-frontend/web
	install -m 0644 web/index.html debian/picam-frontend/usr/share/picam-frontend/web/index.html

override_dh_installsystemd:
	dh_installsystemd --no-restart-on-upgrade --no-stop-on-upgrade

override_dh_dwz:
	# dwz deduplicates DWARF debug info across multiple binaries in a
	# package; this package ships exactly one, and dwz doesn't
	# understand the DWARF layout Go's own linker produces anyway
	# (fails with "Found compressed .debug_aranges section, not
	# attempting dwz compression"). Skip it rather than work around it.

override_dh_auto_clean:
	dh_auto_clean
	rm -f picam-frontend
	rm -rf debian/.gocache
